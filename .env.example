# Lichess OAuth Public Client ID (used in PKCE flow from the browser).
# Register your app at https://lichess.org/account/oauth/app
NEXT_PUBLIC_LICHESS_CLIENT_ID=repertoire-scanner.local

# Canonical site origin used by sitemap.xml, robots.txt, and OG tags.
# In production, set to the deployed URL (no trailing slash). On Vercel,
# falls back to VERCEL_PROJECT_PRODUCTION_URL automatically if omitted.
# NEXT_PUBLIC_SITE_URL=https://repertoire-scanner.example.com
